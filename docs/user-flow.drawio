        </mxCell>
        <mxCell id="note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#06b6d4;fontSize=14;spacingLeft=10;spacingTop=8;" value="Комментарий:&#xa;Если запрос списковый (например, «Выведи список водителей»),&#xa;система принудительно выбирает отображение в виде таблицы." vertex="1">
