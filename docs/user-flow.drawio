<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="user-flow" name="User Flow">
    <mxGraphModel dx="2012" dy="1382" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;" value="User Flow: обработка запроса в чате" vertex="1">
          <mxGeometry height="40" width="860" x="520" y="20" as="geometry" />
        </mxCell>
        <mxCell id="u1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=14;spacingLeft=10;spacingTop=8;" value="1. Пользователь вводит запрос&#xa;в чат интерфейса" vertex="1">
          <mxGeometry height="110" width="260" x="80" y="120" as="geometry" />
        </mxCell>
        <mxCell id="u2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=14;spacingLeft=10;spacingTop=8;" value="2. Frontend отправляет&#xa;POST /api/v1/query/stream" vertex="1">
          <mxGeometry height="110" width="300" x="390" y="120" as="geometry" />
        </mxCell>
        <mxCell id="u3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#eab308;fontSize=14;" value="3. Проверка intent fallback&#xa;(оффтоп / инъекции)" vertex="1">
          <mxGeometry height="160" width="250" x="760" y="95" as="geometry" />
        </mxCell>
        <mxCell id="u4a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontSize=14;spacingLeft=10;spacingTop=8;" value="4A. Если оффтоп:&#xa;возвращаем пояснение&#xa;без генерации SQL" vertex="1">
          <mxGeometry height="120" width="300" x="1460" y="70" as="geometry" />
        </mxCell>
        <mxCell id="u4b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=14;spacingLeft=10;spacingTop=8;" value="4B. Если запрос валиден:&#xa;OpenRouter генерирует&#xa;SQL + reasoning (stream)" vertex="1">
          <mxGeometry height="120" width="300" x="1080" y="220" as="geometry" />
        </mxCell>
        <mxCell id="u5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=14;spacingLeft=10;spacingTop=8;" value="5. Guardrails проверяют SQL&#xa;(безопасность, запрещенные операции)" vertex="1">
          <mxGeometry height="120" width="330" x="360" y="360" as="geometry" />
        </mxCell>
        <mxCell id="u6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=14;spacingLeft=10;spacingTop=8;" value="6. Выполнение SQL&#xa;в базе данных" vertex="1">
          <mxGeometry height="120" width="240" x="740" y="360" as="geometry" />
        </mxCell>
        <mxCell id="u7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=14;spacingLeft=10;spacingTop=8;" value="7. Постобработка результата:&#xa;auto-select table/chart&#xa;и подготовка данных визуализации" vertex="1">
          <mxGeometry height="120" width="350" x="1080" y="360" as="geometry" />
        </mxCell>
        <mxCell id="u8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=14;spacingLeft=10;spacingTop=8;" value="8. Логирование в query_logs&#xa;(query, sql, thinking, статус)" vertex="1">
          <mxGeometry height="120" width="300" x="1580" y="350" as="geometry" />
        </mxCell>
        <mxCell id="u9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#6366f1;fontSize=14;spacingLeft=10;spacingTop=8;" value="9. Frontend показывает ответ:&#xa;интерпретация, reasoning, SQL,&#xa;таблица или график" vertex="1">
